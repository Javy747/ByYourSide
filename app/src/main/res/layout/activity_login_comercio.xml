<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".LoginComercio">

    <LinearLayout
        android:id="@+id/layout_top_login_comercio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/layout_cd_login_comercio">

        <ImageView
            android:id="@+id/volver_inicio_comercio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:focusable="true"
            android:background="@color/coral"
            android:contentDescription="@string/volver_atras"
            android:padding="10dp"
            android:src="@drawable/flecha_volver"
            app:tint="@android:color/white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/coral"
            android:gravity="center"
            android:paddingLeft="-45dp"
            android:text="@string/login_title"
            android:textColor="@color/white"
            android:textSize="25sp"
            android:textStyle="bold" />

    </LinearLayout>


    <LinearLayout
        android:id="@+id/layout_cd_login_comercio"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/fondo_by_your_side"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_top_login_comercio"
        app:layout_constraintVertical_bias="0.0">


        <androidx.cardview.widget.CardView
            android:id="@+id/cd_login_comercio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="30dp"
            android:backgroundTint="@color/white"
            app:cardCornerRadius="30dp"
            app:cardElevation="90dp">


            <LinearLayout
                android:id="@+id/linear_layout_cd_login_comercio"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="25dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="60dp"
                    android:layout_margin="10dp"
                    android:layout_gravity="center"
                    android:text="@string/inicia_sesion"
                    android:textColor="@color/black"
                    android:textSize="35sp"
                    android:textAlignment="center"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/et_correo_comercio_login"
                    android:layout_width="wrap_content"
                    android:layout_height="55dp"
                    android:layout_margin="10dp"
                    android:background="@drawable/custom_edit_text"
                    android:drawableLeft="@drawable/home_asset"
                    android:drawablePadding="4dp"
                    android:ems="10"
                    android:hint="@string/hint_email_comercio"
                    android:inputType="textEmailAddress"
                    android:paddingLeft="5dp"
                    android:paddingRight="15dp"
                    android:textColor="@color/black"
                    android:textSize="25sp"
                    android:lines="1"
                    android:scrollHorizontally="true"
                    android:ellipsize="end"/>

                <EditText
                    android:id="@+id/et_contrasenha_comercio_login"
                    android:layout_width="wrap_content"
                    android:layout_height="55dp"
                    android:layout_margin="10dp"
                    android:background="@drawable/custom_edit_text"
                    android:drawableLeft="@drawable/lock_asset"
                    android:drawablePadding="4dp"
                    android:ems="10"
                    android:hint="@string/hint_password"
                    android:inputType="textPassword"
                    android:paddingLeft="5dp"
                    android:paddingRight="15dp"
                    android:textColor="@color/black"
                    android:textSize="25sp" />

                <TextView
                    android:id="@+id/tv_recuperar_contrasenha_comercio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pregunta_rc"
                    android:textAlignment="center"
                    android:textColor="@color/dark_gray"
                    android:textSize="16sp"
                    android:layout_marginTop="10dp"/>

                <Button
                    android:id="@+id/btn_login_comercio"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginLeft="20dp"
                    android:layout_marginRight="20dp"
                    android:layout_marginBottom="10dp"
                    android:backgroundTint="@color/coral"
                    android:text="@string/login"
                    android:textSize="18sp"
                    android:textColor="@color/white"/>

        <!--

                <Button
                    android:id="@+id/btn_login_email_comercio"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginLeft="20dp"
                    android:layout_marginRight="20dp"
                    android:layout_marginBottom="20dp"
                    android:backgroundTint="@color/coral"
                    android:text="@string/login_email_comercio"
                    android:textColor="@color/white"
                    android:textSize="18sp" />

                                                                                   -->

                <TextView
                    android:id="@+id/tv_prengunta_login_comercio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pregunta_registro_comercio"
                    android:textAlignment="center"
                    android:textColor="@color/dark_gray"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/btn_crear_cuenta_comercio"
                    android:layout_width="200dp"
                    android:layout_height="50dp"
                    android:layout_gravity="center"
                    android:layout_margin="20dp"
                    android:backgroundTint="@color/coral"
                    android:text="@string/crear_cuenta"
                    android:textSize="18sp"
                    android:textColor="@color/white" />


            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>