<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".RegistroComercio">


    <LinearLayout
        android:id="@+id/layout_top_registro_comercio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/scroll_view_registro_comercio">

        <ImageView
            android:id="@+id/volver_login_comercio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:focusable="true"
            android:background="@color/coral"
            android:contentDescription="@string/volver_atras"
            android:padding="10dp"
            android:src="@drawable/flecha_volver"
            app:tint="@android:color/white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/coral"
            android:gravity="center"
            android:paddingLeft="-45dp"
            android:text="@string/login_title"
            android:textColor="@color/white"
            android:textSize="25sp"
            android:textStyle="bold" />
    </LinearLayout>


    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view_registro_comercio"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layout_top_registro_comercio">

        <LinearLayout
            android:id="@+id/layout_registro_comercio"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/fondo_by_your_side"
            android:gravity="top"
            android:orientation="vertical"
            android:paddingBottom="20dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.0">


            <androidx.cardview.widget.CardView
                android:id="@+id/cd_login_cliente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="30dp"
                android:backgroundTint="@color/white"
                app:cardCornerRadius="30dp"
                app:cardElevation="90dp">


                <LinearLayout
                    android:id="@+id/linear_layout_cd_login_cliente"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="25dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="60dp"
                        android:layout_margin="10dp"
                        android:layout_gravity="center"
                        android:text="@string/crea_tu_cuenta"
                        android:textColor="@color/black"
                        android:textSize="35sp"
                        android:textAlignment="center"
                        android:textStyle="bold"/>

                    <EditText
                        android:id="@+id/et_nif_comercio_registro"
                        android:layout_width="wrap_content"
                        android:layout_height="55dp"
                        android:layout_margin="10dp"
                        android:background="@drawable/custom_edit_text"
                        android:ems="10"
                        android:hint="@string/hint_nif_comercio"
                        android:inputType="text"
                        android:paddingLeft="15dp"
                        android:paddingRight="15dp"
                        android:textColor="@color/black"
                        android:textSize="25sp" />

                    <EditText
                        android:id="@+id/et_nombre_comercio_registro"
                        android:layout_width="wrap_content"
                        android:layout_height="55dp"
                        android:layout_margin="10dp"
                        android:background="@drawable/custom_edit_text"
                        android:ems="10"
                        android:hint="@string/hint_nombre_comercio"
                        android:inputType="text"
                        android:paddingLeft="15dp"
                        android:paddingRight="15dp"
                        android:textColor="@color/black"
                        android:textSize="25sp" />

                    <Spinner
                        android:id="@+id/spr_pais_comercio"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:layout_margin="10dp"
                        android:background="@drawable/custom_edit_text" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/stch_ecommerce"
                        android:layout_width="wrap_content"
                        android:layout_height="55dp"
                        android:layout_margin="10dp"
                        android:paddingStart="15dp"
                        android:text="@string/e_comerce"
                        android:textSize="22sp"
                        android:textAlignment="center"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        app:thumbTint="@color/switch_thumb_tint"
                        app:trackTint="@color/switch_track_tint"/>

                <!--
                    <Spinner
                        android:id="@+id/spr_provincia_comercio"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:layout_margin="10dp"
                        android:background="@drawable/custom_edit_text" />

                    <Spinner
                        android:id="@+id/spr_municipio_comercio"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:layout_margin="10dp"
                        android:background="@drawable/custom_edit_text" />
                -->

                    <EditText
                        android:id="@+id/et_provincia_comercio_registro"
                        android:layout_width="wrap_content"
                        android:layout_height="55dp"
                        android:layout_margin="10dp"
                        android:background="@drawable/custom_edit_text"
                        android:ems="10"
                        android:hint="@string/provincia"
                        android:inputType="text"
                        android:paddingLeft="15dp"
                        android:paddingRight="15dp"
                        android:textColor="@color/black"
                        android:textSize="25sp" />

                    <EditText
                        android:id="@+id/et_municipio_comercio_registro"
                        android:layout_width="wrap_content"
                        android:layout_height="55dp"
                        android:layout_margin="10dp"
                        android:background="@drawable/custom_edit_text"
                        android:ems="10"
                        android:hint="@string/municipio"
                        android:inputType="text"
                        android:paddingLeft="15dp"
                        android:paddingRight="15dp"
                        android:textColor="@color/black"
                        android:textSize="25sp" />

                    <EditText
                        android:id="@+id/et_calle_comercio_registro"
                        android:layout_width="wrap_content"
                        android:layout_height="55dp"
                        android:layout_margin="10dp"
                        android:background="@drawable/custom_edit_text"
                        android:ems="10"
                        android:hint="@string/calle"
                        android:inputType="text"
                        android:paddingLeft="15dp"
                        android:paddingRight="15dp"
                        android:textColor="@color/black"
                        android:textSize="25sp" />

                    <EditText
                        android:id="@+id/et_calle_numero_comercio_registro"
                        android:layout_width="wrap_content"
                        android:layout_height="55dp"
                        android:layout_margin="10dp"
                        android:background="@drawable/custom_edit_text"
                        android:ems="10"
                        android:hint="@string/numero_local"
                        android:inputType="text"
                        android:paddingLeft="15dp"
                        android:paddingRight="15dp"
                        android:textColor="@color/black"
                        android:textSize="25sp" />

                    <EditText
                        android:id="@+id/et_cp_comercio_registro"
                        android:layout_width="wrap_content"
                        android:layout_height="55dp"
                        android:layout_margin="10dp"
                        android:background="@drawable/custom_edit_text"
                        android:ems="10"
                        android:hint="@string/codigo_postal"
                        android:inputType="text"
                        android:paddingLeft="15dp"
                        android:paddingRight="15dp"
                        android:textColor="@color/black"
                        android:textSize="25sp" />

                    <EditText
                        android:id="@+id/et_web_comercio_registro"
                        android:layout_width="wrap_content"
                        android:layout_height="55dp"
                        android:layout_margin="10dp"
                        android:background="@drawable/custom_edit_text"
                        android:ems="10"
                        android:hint="@string/web"
                        android:inputType="text"
                        android:paddingLeft="15dp"
                        android:paddingRight="15dp"
                        android:textColor="@color/black"
                        android:textSize="25sp" />

                    <EditText
                        android:id="@+id/et_telefono_comercio_registro"
                        android:layout_width="wrap_content"
                        android:layout_height="55dp"
                        android:layout_margin="10dp"
                        android:background="@drawable/custom_edit_text"
                        android:ems="10"
                        android:hint="@string/hint_telefono"
                        android:inputType="text"
                        android:paddingLeft="15dp"
                        android:paddingRight="15dp"
                        android:textColor="@color/black"
                        android:textSize="25sp" />

                    <EditText
                        android:id="@+id/et_email_comercio_registro"
                        android:layout_width="wrap_content"
                        android:layout_height="55dp"
                        android:layout_margin="10dp"
                        android:background="@drawable/custom_edit_text"
                        android:drawableLeft="@drawable/home_asset"
                        android:drawablePadding="4dp"
                        android:ems="10"
                        android:hint="@string/hint_email_comercio"
                        android:inputType="textEmailAddress"
                        android:paddingLeft="5dp"
                        android:paddingRight="15dp"
                        android:textColor="@color/black"
                        android:textSize="25sp" />

                    <EditText
                        android:id="@+id/et_contrasenha_comercio_registro"
                        android:layout_width="wrap_content"
                        android:layout_height="55dp"
                        android:layout_margin="10dp"
                        android:background="@drawable/custom_edit_text"
                        android:drawableLeft="@drawable/lock_asset"
                        android:drawablePadding="4dp"
                        android:ems="10"
                        android:hint="@string/hint_password"
                        android:inputType="textPassword"
                        android:paddingLeft="5dp"
                        android:paddingRight="15dp"
                        android:textColor="@color/black"
                        android:textSize="25sp" />

                    <EditText
                        android:id="@+id/et_confirmar_contrasenha_comercio_registro"
                        android:layout_width="wrap_content"
                        android:layout_height="55dp"
                        android:layout_margin="10dp"
                        android:background="@drawable/custom_edit_text"
                        android:drawableLeft="@drawable/lock_asset"
                        android:drawablePadding="4dp"
                        android:ems="10"
                        android:hint="@string/hint_confirmar_password"
                        android:inputType="textPassword"
                        android:paddingLeft="5dp"
                        android:paddingRight="15dp"
                        android:textColor="@color/black"
                        android:textSize="25sp" />


                    <Button
                        android:id="@+id/btn_registro_comercio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="7dp"
                        android:backgroundTint="@color/coral"
                        android:text="@string/hint_registro_comercio"
                        android:textSize="18sp"
                        android:textColor="@color/white" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>